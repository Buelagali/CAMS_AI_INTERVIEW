# Server Configuration
PORT=5000
NODE_ENV=development

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Authentication
JWT_SECRET=cams-prod-secret-change-in-production
JWT_EXPIRY=2h
JWT_DISABLED=false

# Redis Session Store
REDIS_URL=redis://localhost:6379

# Cluster Mode
WORKERS=3

# GPU Inference
GPU_DISABLED=false

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Model Registry
MODEL_REGISTRY_DIR=./models/registry

# Training Pipeline
PYTHON_PATH=python3
